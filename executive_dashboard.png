    "from sqlalchemy import create_engine\n",
    "\n",
    "engine = create_engine(\n",
    "    \"mysql+pymysql://root:1997@localhost/food_delivery_db\"\n",
    ")\n",
    "\n",
    "df.to_sql(\n",
    "    \"food_delivery\",\n",
    "    con=engine,\n",
    "    if_exists=\"replace\",\n",
    "    index=False\n",
    ")"
   ]
